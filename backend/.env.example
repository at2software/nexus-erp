APP_NAME=NEXUS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
FRONTEND_PORT=3200
BACKEND_PORT=8000
APP_URL=http://localhost:3200/backend
API_URL=http://localhost:3200/backend/api/
APP_DIR="/backend"
APP_AUTH=token
#APP_AUTH=keycloak

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=changeme

BROADCAST_CONNECTION=reverb
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

REVERB_APP_ID=nexus
REVERB_APP_KEY=nexus-key
REVERB_APP_SECRET=nexus-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http

# Laravel's built-in reverb config reads PUSHER_* — keep these in sync with REVERB_* above
PUSHER_APP_ID=nexus
PUSHER_APP_KEY=nexus-key
PUSHER_APP_SECRET=nexus-secret
PUSHER_HOST=localhost
PUSHER_PORT=6001
PUSHER_SCHEME=http

# Keycloak configuration
KEYCLOAK_REALM_PUBLIC_KEY=""
KEYCLOAK_BASE_URL = ""
KEYCLOAK_REALM = ""
KEYCLOAK_CLIENT_ID = ""

# Initial admin account (used by InsertBasicRoles seeder)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# at2connect - QR-code based contact portal (optional module)
AT2CONNECT_URL=
AT2CONNECT_DEFAULT_CHANNEL_ID=
AT2CONNECT_DEFAULT_CHANNEL_NAME=Support
AT2CONNECT_USER_ID=